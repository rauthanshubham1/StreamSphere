generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  firstname  String?
  lastname   String?
  username   String?  @unique
  profilepic String?  @default("https://img.freepik.com/premium-vector/profile-icon_933463-643.jpg")
  about      String?
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  // One-to-Many 
  videos     Video[]
}

model Video {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  description String
  video_url   String?
  tags        String[]
  created_at  DateTime @default(now())
  // Many-to-One
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
